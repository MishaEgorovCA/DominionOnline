{
  "name": "dominion-online",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @dominion/engine && npm run build -w @dominion/server && npm run build -w @dominion/client",
    "dev": "concurrently \"npm run dev -w @dominion/server\" \"npm run dev -w @dominion/client\"",
    "test": "npm run test -w @dominion/engine",
    "lint": "eslint packages/*/src --ext .ts,.tsx"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2"
  }
}
